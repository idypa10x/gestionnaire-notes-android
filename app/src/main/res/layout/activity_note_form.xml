<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/formContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/noteCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#219653">

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:background="@android:color/transparent"
            android:inputType="textCapSentences"
            android:padding="4dp"/>

        <EditText
            android:id="@+id/etContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:hint="Contenu"
            android:textSize="14sp"
            android:textColor="#000000"
            android:textColorHint="#80000000"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top"
            android:padding="4dp"/>

    </LinearLayout>

    <!-- PALETTE DE COULEURS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <View
            android:id="@+id/color_vert"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#219653"/>

        <View
            android:id="@+id/color_rouge"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#EB5757"/>

        <View
            android:id="@+id/color_bleu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#2F80ED"/>

        <View
            android:id="@+id/color_jaune"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#F2C94C"/>

        <View
            android:id="@+id/color_orange"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#F2994A"/>

        <View
            android:id="@+id/color_gris"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/color_circle"
            android:backgroundTint="#828282"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="Créer"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000"/>

</LinearLayout>